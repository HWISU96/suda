# Infrastructure (PostgreSQL / Redis)
POSTGRES_DB=appdb
POSTGRES_PORT=5432

# Backend runtime
SPRING_PROFILES_ACTIVE=dev
DB_URL=jdbc:postgresql://localhost:5432/appdb
DB_USERNAME=appuser
DB_PASSWORD=apppassword
AUTH_JWT_SECRET=change-this-dev-jwt-secret-at-least-32-bytes
AUTH_JWT_ISSUER=s14p31a404-dev
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=1209600
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=Lax
AUTH_REFRESH_COOKIE_PATH=/
SECURITY_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:8080
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# App ports
BACKEND_PORT=8080

# Mobile (Android)
# 에뮬레이터에서 개발 PC localhost를 가리키는 주소: 10.0.2.2
# 실기기 테스트 시 개발 PC의 실제 LAN IP로 변경 필요 (예: 192.168.x.x)
MOBILE_API_BASE_URL=http://10.0.2.2:8080/api/
